#!/usr/bin/env bash
# Pre-push quality gate: run the full local suite before a push hits the remote,
# so CI red is caught here instead of after a round-trip. Delegates to
# scripts/quality-gate.sh — the same gates scripts/bump-version.sh and
# scripts/publish-crates.sh enforce (minus their release-only bundle build /
# publishability check).
#
# Enable once per clone:  git config core.hooksPath .githooks
#   (scripts/bump-version.sh arms this idempotently at release time.)
# Bypass for a single push (e.g. a WIP branch):  git push --no-verify
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"

# Git exports repository-local environment variables (notably GIT_DIR and
# GIT_WORK_TREE) to hooks. If they leak into the test suite, any `git init` or
# `git commit` spawned by a test targets this checkout instead of its tempdir.
# Capture the root first, then clear every local variable before running tools.
for name in $(git rev-parse --local-env-vars); do
  unset "$name"
done

cd "$repo_root"

if ! scripts/quality-gate.sh; then
  printf '\033[1;31m✗ pre-push: quality gate failed\033[0m\n' >&2
  printf '  (Bypass once with: git push --no-verify)\n' >&2
  exit 1
fi
