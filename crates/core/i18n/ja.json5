    // ── Issue / Discussion templates (placeholders: {app_version} {os} {os_version} {arch} {ua})
    "tpl.bug": "## 問題の説明\n<!-- バグの内容を簡潔に記述してください -->\n\n\n## 再現手順\n1.\n2.\n3.\n\n## 期待される動作\n\n\n## 実際の動作\n\n\n## 環境\n- **Markon**: v{app_version}\n- **OS**: {os} {os_version} ({arch})\n- **UA**: {ua}\n",
    "tpl.idea": "## 概要\n<!-- どのような機能や改善を望みますか? -->\n\n\n## 使用場面 / 動機\n<!-- この提案はどのような課題を解決しますか? -->\n\n\n## 実装案 (任意)\n\n\n---\n*Markon v{app_version} · {os} {os_version}*\n",
    "tpl.ask": "## 質問内容\n\n\n\n## 試したこと (任意)\n\n\n\n---\n*Markon v{app_version} · {os} {os_version}*\n",
    "tpl.title.bug":  "[Bug] ",
    "tpl.title.idea": "",
    "tpl.title.ask":  "",

