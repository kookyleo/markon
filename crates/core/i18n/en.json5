    // ── Tips — Key features ──────────────────────────────────
    "tips.features":   "More",
    "tips.feat.search.title": "Full-text search",
    "tips.feat.search.desc":  "CJK-aware tokenization, case-insensitive. Press / in the browser to search file contents in real time",
    "tips.feat.viewed.title": "Viewed tracking",
    "tips.feat.viewed.desc":  "Inspired by GitHub PR reviews — mark reading progress at block level, auto-saved",
    "tips.feat.edit.title":   "Live editing",
    "tips.feat.edit.desc":    "Press e to edit Markdown source directly in the browser with syntax highlighting + live preview; save with ⌘/Ctrl+S",
    "tips.feat.annot.title":  "Annotations & Highlights",
    "tips.feat.annot.desc":   "Select text to highlight, strikethrough, or add notes",
    "tips.feat.shared.title": "Shared annotations & viewed state",
    "tips.feat.shared.desc":  "Ideal for multi-device reading or team collaboration",
    "tips.feat.print.title":  "Section print",
    "tips.feat.print.desc":   "Click the print link next to a heading to print only that section",
    "tips.feat.live.title":   "Live collaboration",
    "tips.feat.live.desc":    "Sync reading position across devices or teammates; press l in the browser to swap leader/follower, Shift+l to disable",
    "tips.feat.chat.title":   "AI assistant",
    "tips.feat.chat.desc":    "Embedded AI assistant grounded in the current document; press c to open (Shift+c toggles in-page / popout window)",
    "tips.feat.access.title": "Access codes",
    "tips.feat.access.desc":  "Gate remote access with a collaborator access code: set a server-wide code in Server and access, or a per-workspace code via that workspace's collaborator lock icon. Remote viewers enter it at a browser gate (the gate input has a press-and-hold eye to reveal it). Local access is always open",
    "tips.feat.customize.title": "Customize",
    "tips.feat.customize.desc":  "Tweak theme colors (light/dark), UI font/size and panel opacity in Page styles; rebind every key in Shortcuts",

