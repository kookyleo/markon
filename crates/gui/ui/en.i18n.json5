    // ── Issue / Discussion templates (placeholders: {app_version} {os} {os_version} {arch} {ua})
    "tpl.bug": "## Description\n<!-- A clear description of the bug -->\n\n\n## Steps to reproduce\n1.\n2.\n3.\n\n## Expected behavior\n\n\n## Actual behavior\n\n\n## Environment\n- **Markon**: v{app_version}\n- **OS**: {os} {os_version} ({arch})\n- **UA**: {ua}\n",
    "tpl.idea": "## Summary\n<!-- What would you like to see? -->\n\n\n## Motivation / Use case\n<!-- What problem does this solve for you? -->\n\n\n## Possible implementation (optional)\n\n\n---\n*Markon v{app_version} · {os} {os_version}*\n",
    "tpl.ask": "## Question\n\n\n\n## What have you tried (optional)\n\n\n\n---\n*Markon v{app_version} · {os} {os_version}*\n",
    "tpl.title.bug":  "[Bug] ",
    "tpl.title.idea": "",
    "tpl.title.ask":  "",

