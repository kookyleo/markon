{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markon",
  "version": "0.8.0",
  "identifier": "dev.kookyleo.markon",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "markon",
        "width": 600,
        "height": 520,
        "minWidth": 520,
        "minHeight": 420,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/kookyleo/markon/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0RDA5QTQ2MjYwMTAyQzIKUldUQ0FnRW1ScHJRWkFuTWx0VXpWc2ZLeFp4QXpobkE5UGdRSzVnWlJGRWNFWTBMTmowZ25lWWkK"
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/256x256.png", "icons/512x512.png", "icons/icon.icns", "icons/icon.ico"],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown File",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "installerHooks": "nsis/file-association.nsh"
      }
    }
  }
}
